<%- include('../partials/header') %>
  <section class="account-page">
    <h1>My Wishlist</h1>
    <div class="account-grid">
      <div class="account-sidebar">
        <a href="/account">Dashboard</a>
        <a href="/account/orders">My Orders</a>
        <a href="/account/wishlist" class="active">Wishlist</a>
        <a href="/account/profile">Profile</a>
        <a href="/account/logout">Logout</a>
      </div>
      <div class="account-content">
        <% if (items.length) { %>
          <div class="product-grid">
            <% items.forEach(function(p) { %>
              <div class="product-card">
                <a href="/shop/product/<%= p.id %>"><img src="<%= p.image %>" alt="<%= p.name %>" class="product-img"></a>
                <div class="product-info">
                  <h3><%= p.name %></h3>
                  <div class="product-price">
                    <span class="price-current">GH₵<%= parseFloat(p.price).toFixed(2) %></span>
                  </div>
                  <div class="product-actions">
                    <form action="/shop/cart/add/<%= p.id %>" method="POST" style="display:inline">
                      <button type="submit" class="btn btn-sm btn-primary">Add to Cart</button>
                    </form>
                    <form action="/account/wishlist/remove/<%= p.id %>" method="POST" style="display:inline">
                      <button type="submit" class="btn btn-sm btn-danger">Remove</button>
                    </form>
                  </div>
                </div>
              </div>
            <% }); %>
          </div>
        <% } else { %>
          <p>Your wishlist is empty. <a href="/shop">Browse products</a></p>
        <% } %>
      </div>
    </div>
  </section>
<%- include('../partials/footer') %>
