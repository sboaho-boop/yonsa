<%- include('../partials/header') %>
  <section class="account-page">
    <h1>My Account</h1>
    <div class="account-grid">
      <div class="account-sidebar">
        <a href="/account" class="active">Dashboard</a>
        <a href="/account/orders">My Orders</a>
        <a href="/account/wishlist">Wishlist</a>
        <a href="/account/profile">Profile</a>
        <a href="/account/logout">Logout</a>
      </div>
      <div class="account-content">
        <h2>Welcome, <%= currentCustomer.name %>!</h2>

        <div class="account-stats">
          <div class="stat-card">
            <h3><%= orders.length %></h3>
            <p>Orders</p>
          </div>
          <div class="stat-card">
            <h3><%= wishlist.length %></h3>
            <p>Wishlist Items</p>
          </div>
        </div>

        <h3>Recent Orders</h3>
        <% if (orders.length) { %>
          <table class="admin-table">
            <thead><tr><th>Order #</th><th>Total</th><th>Status</th><th>Date</th><th></th></tr></thead>
            <tbody>
              <% orders.forEach(function(o) { %>
                <tr>
                  <td><%= o.order_ref %></td>
                  <td>GH₵<%= parseFloat(o.total).toFixed(2) %></td>
                  <td><span class="status <%= o.status %>"><%= o.status %></span></td>
                  <td><%= new Date(o.created_at).toLocaleDateString() %></td>
                  <td><a href="/shop/order/<%= o.order_ref %>" class="btn btn-sm">View</a></td>
                </tr>
              <% }); %>
            </tbody>
          </table>
        <% } else { %>
          <p>No orders yet. <a href="/shop">Start shopping!</a></p>
        <% } %>
      </div>
    </div>
  </section>
<%- include('../partials/footer') %>
