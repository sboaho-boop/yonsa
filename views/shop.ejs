<%- include('partials/header') %>
  <section class="shop-page">
    <h1>Shop</h1>
    <div class="shop-header">
      <div class="categories">
        <a href="/shop" class="<%= !selectedCategory ? 'active' : '' %>">All</a>
        <% categories.forEach(function(c) { %>
          <a href="/shop?category=<%= encodeURIComponent(c.name) %>" class="<%= selectedCategory === c.name ? 'active' : '' %>"><%= c.name %></a>
        <% }); %>
      </div>
      <form action="/shop" method="GET" class="search-form">
        <input type="text" name="search" placeholder="Search products..." value="<%= search %>">
        <button type="submit" class="btn btn-sm btn-primary">Search</button>
      </form>
    </div>
    <div class="product-grid">
      <% if (products.length) { %>
        <% products.forEach(function(p) { %>
          <div class="product-card">
            <a href="/shop/product/<%= p.id %>"><img src="<%= p.image %>" alt="<%= p.name %>" class="product-img" loading="lazy"></a>
            <div class="product-info">
              <h3><%= p.name %></h3>
              <p class="product-category"><%= p.category_name || '' %></p>
              <div class="product-price">
                <% if (p.original_price && p.original_price > p.price) { %>
                  <span class="price-current">GH₵<%= parseFloat(p.price).toFixed(2) %></span>
                  <span class="price-old">GH₵<%= parseFloat(p.original_price).toFixed(2) %></span>
                <% } else { %>
                  <span class="price-current">GH₵<%= parseFloat(p.price).toFixed(2) %></span>
                <% } %>
              </div>
              <form action="/shop/cart/add/<%= p.id %>" method="POST">
                <button type="submit" class="btn btn-sm btn-primary" style="width:100%">Add to Cart</button>
              </form>
            </div>
          </div>
        <% }); %>
      <% } else { %>
        <p class="no-products">No products found.</p>
      <% } %>
    </div>
  </section>
<%- include('partials/footer') %>
