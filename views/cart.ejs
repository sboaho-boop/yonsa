<%- include('partials/header') %>
  <section class="cart-page">
    <h1>Shopping Cart</h1>
    <% if (typeof couponError !== 'undefined' && couponError) { %><p class="error-msg"><%= couponError %></p><% } %>
    <% if (cart.length) { %>
      <div class="cart-items">
        <% cart.forEach(function(item) { %>
          <div class="cart-item">
            <img src="<%= item.image %>" alt="<%= item.name %>" class="cart-item-img">
            <div class="cart-item-info">
              <h3><%= item.name %></h3>
              <% if (item.variant) { %><p class="cart-item-variant"><%= item.variant %></p><% } %>
              <p class="price-current">GH₵<%= parseFloat(item.price).toFixed(2) %></p>
            </div>
            <form action="/shop/cart/update/<%= item.cartKey %>" method="POST" class="cart-item-qty">
              <input type="number" name="quantity" value="<%= item.quantity %>" min="1" max="99">
              <button type="submit" class="btn btn-sm">Update</button>
            </form>
            <p class="cart-item-total">GH₵<%= (item.price * item.quantity).toFixed(2) %></p>
            <form action="/shop/cart/remove/<%= item.cartKey %>" method="POST">
              <button type="submit" class="btn btn-sm btn-danger">Remove</button>
            </form>
          </div>
        <% }); %>
      </div>

      <div class="coupon-section">
        <form action="/shop/cart/apply-coupon" method="POST" class="coupon-form">
          <input type="text" name="code" placeholder="Enter coupon code" value="<%= coupon ? coupon.code : '' %>">
          <button type="submit" class="btn btn-sm">Apply</button>
        </form>
        <% if (coupon) { %><span class="coupon-applied">Coupon applied: <%= coupon.code %> (<%= coupon.discount_type === 'percentage' ? coupon.discount_value + '%' : 'GH₵' + coupon.discount_value %> off)</span><% } %>
      </div>

      <div class="cart-summary">
        <h3>Subtotal: GH₵<%= subtotal.toFixed(2) %></h3>
        <% if (discount > 0) { %>
          <p class="cart-discount">Discount: -GH₵<%= discount.toFixed(2) %></p>
          <h3>Total: GH₵<%= (subtotal - discount).toFixed(2) %></h3>
        <% } %>
        <a href="/shop/checkout" class="btn btn-primary">Proceed to Checkout</a>
        <a href="/shop" class="btn btn-secondary">Continue Shopping</a>
      </div>
    <% } else { %>
      <div class="empty-cart">
        <p>Your cart is empty.</p>
        <a href="/shop" class="btn btn-primary">Start Shopping</a>
      </div>
    <% } %>
  </section>
<%- include('partials/footer') %>
