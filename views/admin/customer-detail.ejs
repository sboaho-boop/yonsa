<%- include('../partials/header') %>
  <section class="admin-page">
    <h1>Customer: <%= customer.name %></h1>
    <div class="admin-section">
      <p><strong>Email:</strong> <%= customer.email %></p>
      <p><strong>Phone:</strong> <%= customer.phone || '-' %></p>
      <p><strong>Address:</strong> <%= customer.address || '-' %></p>
      <p><strong>Joined:</strong> <%= new Date(customer.created_at).toLocaleDateString() %></p>
    </div>
    <div class="admin-section">
      <h2>Order History</h2>
      <% if (orders.length) { %>
        <table class="admin-table">
          <thead><tr><th>Order #</th><th>Total</th><th>Status</th><th>Date</th></tr></thead>
          <tbody>
            <% orders.forEach(function(o) { %>
              <tr>
                <td><%= o.order_ref || o.id %></td>
                <td>GH₵<%= parseFloat(o.total).toFixed(2) %></td>
                <td><span class="status <%= o.status %>"><%= o.status %></span></td>
                <td><%= new Date(o.created_at).toLocaleDateString() %></td>
              </tr>
            <% }); %>
          </tbody>
        </table>
      <% } else { %><p>No orders yet.</p><% } %>
    </div>
    <a href="/admin/customers" class="btn btn-secondary">Back</a>
  </section>
<%- include('../partials/footer') %>
