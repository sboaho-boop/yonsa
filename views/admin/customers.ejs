<%- include('../partials/header') %>
  <section class="admin-page">
    <h1>Customers</h1>
    <table class="admin-table">
      <thead><tr><th>Name</th><th>Email</th><th>Phone</th><th>Orders</th><th>Total Spent</th><th>Joined</th><th></th></tr></thead>
      <tbody>
        <% customers.forEach(function(c) { %>
          <tr>
            <td><%= c.name %></td>
            <td><%= c.email %></td>
            <td><%= c.phone || '-' %></td>
            <td><%= c.order_count || 0 %></td>
            <td>GH₵<%= parseFloat(c.total_spent || 0).toFixed(2) %></td>
            <td><%= new Date(c.created_at).toLocaleDateString() %></td>
            <td><a href="/admin/customers/<%= c.id %>" class="btn btn-sm">View</a></td>
          </tr>
        <% }); %>
      </tbody>
    </table>
  </section>
<%- include('../partials/footer') %>
